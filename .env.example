# Strands Demo — Environment Configuration
# Copy this file to .env and populate from CloudFormation stack outputs:
#   aws cloudformation describe-stacks --stack-name strands-demo-cognito --query "Stacks[0].Outputs"
#
# NEVER commit .env to version control. Only .env.example is committed.

# AWS region where the Cognito User Pool is deployed
AWS_REGION=us-east-1

# Cognito User Pool ID (CloudFormation Output: UserPoolId)
# Format: us-east-1_XXXXXXXXX
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX

# Cognito App Client ID (CloudFormation Output: UserPoolClientId)
COGNITO_CLIENT_ID=your-app-client-id-here

# Cognito App Client Secret (CloudFormation Output: UserPoolClientSecret)
# Keep this secret — never share or commit
COGNITO_CLIENT_SECRET=your-app-client-secret-here

# Cognito Hosted UI base URL (CloudFormation Output: UserPoolDomainURL)
# Format: https://{domain-prefix}.auth.{region}.amazoncognito.com
COGNITO_DOMAIN=https://your-domain-prefix.auth.us-east-1.amazoncognito.com

# OAuth2 redirect URI — must match exactly what is registered in the App Client
# For local development: http://localhost:8501
# For Streamlit Community Cloud: https://your-app.streamlit.app
# See .streamlit/secrets.toml.example for SCC TOML secrets format.
COGNITO_REDIRECT_URI=http://localhost:8501

# ── Strands Reasoning Chatbot (feature 003) ───────────────────────────────────

# Anthropic API key — direct Anthropic API access for Claude Sonnet 4.6
# Obtain at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Tavily web search API key — enables the agent's web search tool
# Obtain free tier at: https://app.tavily.com
TAVILY_API_KEY=tvly-...

# Log level for structured logging (optional, default: INFO)
LOG_LEVEL=INFO

# ── AgentCore Runtime (feature 004) ───────────────────────────────────────────
#
# Set AGENTCORE_RUNTIME_ARN to route chat to AgentCore Runtime (managed service mode).
# Leave unset (or remove the line) to use the local in-process agent fallback (feature 003).
#
# How to populate:
#   aws cloudformation describe-stacks \
#     --stack-name strands-demo-agentcore \
#     --query "Stacks[0].Outputs[?OutputKey=='AgentRuntimeArn'].OutputValue" \
#     --output text
#
# Format: arn:aws:bedrock-agentcore:<region>:<account-id>:runtime/<runtime-id>
AGENTCORE_RUNTIME_ARN=

# ── EKS MCP Server (feature 007) ──────────────────────────────────────────────
#
# Optional: override auto-detected region for EKS MCP Server.
# Leave unset to use AWS_REGION (from AgentCore config) or AWS_DEFAULT_REGION.
# EKS_MCP_REGION=us-west-2

# ── AgentCore Browser (feature 013) ─────────────────────────────────────────
#
# Default URL for the browser tool to navigate to when user says "retail store"
# Set to your ALB URL or any publicly accessible website for demo purposes.
RETAIL_STORE_URL=http://k8s-ui-ui-6353f3da9d-613966318.us-east-1.elb.amazonaws.com
