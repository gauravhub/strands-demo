# ── AWS Core Credentials ──────────────────────────────────────────────────────
# IAM user or role access key ID
AWS_ACCESS_KEY_ID=your_access_key_id_here

# IAM secret access key paired with the access key ID
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here

# Temporary session token — leave blank if using long-term IAM credentials
AWS_SESSION_TOKEN=

# AWS region for all service calls (e.g. us-east-1, eu-west-1)
AWS_REGION=us-east-1

# ── Amazon Cognito ────────────────────────────────────────────────────────────
# User Pool ID (format: <region>_<alphanumeric>, e.g. us-east-1_AbCdEfGhI)
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX

# App Client ID — required for all auth flows
COGNITO_APP_CLIENT_ID=your_app_client_id_here

# App Client Secret — only set if your app client is configured as confidential
COGNITO_APP_CLIENT_SECRET=

# Cognito hosted UI domain (e.g. myapp.auth.us-east-1.amazoncognito.com)
COGNITO_DOMAIN=myapp.auth.us-east-1.amazoncognito.com

# OAuth 2.0 callback URL — must be registered in the Cognito app client settings
COGNITO_REDIRECT_URI=http://localhost:8501

# Region where the Cognito User Pool lives (usually same as AWS_REGION)
COGNITO_REGION=us-east-1
