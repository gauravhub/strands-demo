# Streamlit Community Cloud Secrets Template
# ──────────────────────────────────────────
# Paste this into SCC → Settings → Secrets (TOML format).
# Root-level keys are automatically exposed as environment variables.
#
# For local development, copy to .streamlit/secrets.toml (gitignored).

# AWS Cognito (from feature 002 — strands-demo-cognito stack)
COGNITO_USER_POOL_ID = "us-east-1_XXXXXXXXX"
COGNITO_CLIENT_ID = "your-client-id"
COGNITO_CLIENT_SECRET = "your-client-secret"
COGNITO_DOMAIN = "https://your-domain.auth.us-east-1.amazoncognito.com"
COGNITO_REDIRECT_URI = "https://your-app.streamlit.app"
AWS_REGION = "us-east-1"

# API Keys
ANTHROPIC_API_KEY = "sk-ant-..."
TAVILY_API_KEY = "tvly-..."

# AgentCore Runtime (from feature 004 — strands-demo-agentcore stack)
# Leave empty or omit to use local agent fallback mode.
AGENTCORE_RUNTIME_ARN = "arn:aws:bedrock-agentcore:us-east-1:ACCOUNT:runtime/ID"

# Logging
LOG_LEVEL = "INFO"
